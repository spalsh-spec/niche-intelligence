# Copy to .env and fill in to unlock LIVE mode. All optional —
# without them the tool runs on the bundled sample corpus + heuristics.

# YouTube Data API v3 key
YOUTUBE_API_KEY=

# Anthropic API key for Claude analysis + briefs
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: override where outputs are written
# BST_OUTPUT_DIR=./output
